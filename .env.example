# Скопируйте в .env и заполните перед деплоем: cp .env.example .env

# Секрет для подписи JWT. Обязателен, минимум 32 байта.
# Сгенерировать: openssl rand -hex 32
CALENDAR_JWT_SECRET=change-me-to-a-strong-random-secret-min-32-bytes

# Внешний порт, на котором nginx отдаёт приложение.
WEB_PORT=8080

# База данных. По умолчанию SQLite в docker volume calendar-data.
# Для внешней БД укажите, например: postgresql+psycopg://user:pass@host:5432/calendar
CALENDAR_DATABASE_URL=sqlite:////app/data/calendar.sqlite

# CORS. При работе через nginx-прокси (VITE_API_URL=/api) можно оставить пустым.
# Для отдельного домена фронтенда: https://calendar.example.com
CALENDAR_CORS_ORIGINS=

# Время жизни access-токена в минутах (по умолчанию 7 дней).
CALENDAR_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Лимиты на публичное создание бронирований.
CALENDAR_BOOKING_RATE_LIMIT_MAX=5
CALENDAR_BOOKING_RATE_LIMIT_WINDOW_SECONDS=60

# Наполнить БД демо-данными при первом старте (ВНИМАНИЕ: seed очищает таблицы).
CALENDAR_SEED_ON_START=false

# База API для сборки фронтенда. По умолчанию /api (nginx проксирует на backend).
VITE_API_URL=/api
